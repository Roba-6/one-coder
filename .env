# ===== Environment Configurations =====================================================

# ----- One Coder ----------------------------------------------------------------------

#APP_NAME="One Coder"
#
# Application type (value: "cms" or "admin")
APP_TYPE=cms

# ----- One Coder UI -------------------------------------------------------------------
# Basic
UI_NAME="One Coder"

UI_LANGUAGE=en

UI_URL=http://localhost:5173
# The base URL of the backend API that the frontend connects to
UI_API=http://localhost:8000

UI_INIT=True

UI_TYPE=$APP_TYPE

# ----- One Coder API ------------------------------------------------------------------
# Basic Items
# Application type (value: "cms" or "admin")
API_APP_TYPE=$APP_TYPE
# Debug mode (value: "True" or "False")
# When debug mode is set to False, the Swagger UI and ReDoc interfaces are disabled.
API_DEBUG=True
# Basic
API_TITLE="One Coder API"

API_LANGUAGE=en

API_TIME_ZONE=Asia/Tokyo

API_FEATURE_CONTROL=True

API_RESPONSE_LANGUAGE=ja

API_LOCALES_PATH=backend/src/one_coder_api/locales

API_CORS_ORIGINS=http://localhost,http://localhost:5173

# Secret key: can be generated using the command `openssl rand -hex 32`
API_SECRET_KEY=opf-insecure-develop
# Access token expiration time (in minutes)
API_ACCESS_TOKEN_EXPIRE=15
# Refresh token expiration time (in minutes)
API_REFRESH_TOKEN_EXPIRE=4320
# Controls whether the SameSite attribute is applied to authentication cookies.
# (Value: "strict", "lax", or "none").
API_REFRESH_SAME_SITE=strict
# Controls whether the refresh token cookie requires HTTPS
API_REFRESH_TOKEN_SECURE=False


# Database
API_DB_ENGINE=postgresql
API_DB_HOST=localhost
API_DB_PORT=5432
API_DB_NAME=oc_db
API_DB_USER=postgres
API_DB_PASS=postgres

# Log
API_LOG_PATH=../logs
API_LOG_NAME=api
API_LOG_ECHO_SQL=True
# Specifies the default format of log messages.
API_LOG_FORMAT="%(asctime)s %(levelname)s\t%(name)s %(message)s"

# ----- OS -----------------------------------------------------------------------------
UID=1000
GID=1000
